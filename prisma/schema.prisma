generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Agency {
  id          String   @id @default(uuid())
  name        String   @unique
  type        String   // 'GOVT', 'NGO', 'UN', 'VOLUNTEER'
  contactInfo String?
  createdAt   DateTime @default(now())

  activities  ActivityRegistry[]
  funds       FundDisbursement[]
}

model ActivityRegistry {
  id              String   @id @default(uuid())
  agencyId        String
  agency          Agency   @relation(fields: [agencyId], references: [id])
  
  title           String
  activityType    String   // 'MEDICAL', 'SHELTER', 'FOOD', 'WATER', 'INFRASTRUCTURE'
  description     String?
  zone            String   // General area
  latitude        Float
  longitude       Float
  
  budget          Float
  beneficiaries   Int
  
  startDate       DateTime
  endDate         DateTime?
  status          String   @default("PLANNED") // 'PLANNED', 'ONGOING', 'COMPLETED'
  
  isDuplicated    Boolean  @default(false)
  duplicateNotes  String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  funds           FundDisbursement[]
}

model FundDisbursement {
  id              String   @id @default(uuid())
  activityId      String
  activity        ActivityRegistry @relation(fields: [activityId], references: [id])
  
  agencyId        String
  agency          Agency   @relation(fields: [agencyId], references: [id])
  
  amount          Float
  disbursedDate   DateTime
  status          String   @default("PLANNED") // 'PLANNED', 'ONGOING', 'COMPLETED'
  purpose         String
  
  latitude        Float
  longitude       Float
  
  createdAt       DateTime @default(now())
}

model DisasterAnalysis {
  id              String   @id @default(uuid())
  disasterType    String   // 'FLOOD', 'EARTHQUAKE', 'CYCLONE'
  region          String
  dateOccurred    DateTime
  
  whatWorked      String
  whatFailed      String
  populationsMissed String?
  
  tags            String   // Comma-separated or JSON string
  
  authorId        String?  // Optional relation to User/Agency
  createdAt       DateTime @default(now())
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("AGENCY_WORKER") // 'ADMIN', 'NODAL_AUTHORITY', 'AGENCY_WORKER'
  agencyName   String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
}
